{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/discover", "destination": "/discover.html" },
    { "source": "/trips", "destination": "/trips.html" },
    { "source": "/chat", "destination": "/chat.html" },
    { "source": "/matches", "destination": "/matches.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/reviews", "destination": "/reviews.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/trip-detail", "destination": "/trip-detail.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/verify-email", "destination": "/verify-email.html" },
    { "source": "/auth-callback", "destination": "/auth-callback.html" }
  ]
}
